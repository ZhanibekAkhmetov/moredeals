generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductCondition {
  NEW
  REFURBISHED
  USED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  PREORDER
  UNKNOWN
}

enum PaymentMethod {
  CREDIT_CARD
  PAYPAL
  KLARNA
  BANK_TRANSFER
  APPLE_PAY
  GOOGLE_PAY
  CASH_ON_DELIVERY
}

enum OfferSource {
  DEMO
  IMPORTED_FEED
}

enum ExtractionStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum MerchantFeedImportStatus {
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  brand       String
  category    String           @default("smartphone")
  modelNumber String?
  description String?
  imageUrl    String?
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([brand])
  @@index([category])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String   @unique
  color     String?
  storageGb Int
  ramGb     Int?
  imageUrl  String?
  ean       String?  @unique
  gtin      String?  @unique
  mpn       String?  @unique
  offers    Offer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, color, storageGb])
  @@index([productId])
}

model Shop {
  id                    String        @id @default(cuid())
  name                  String
  slug                  String        @unique
  baseUrl               String
  trustpilotRating      Decimal?      @db.Decimal(3, 2)
  trustpilotReviewCount Int?          @default(0)
  offers                Offer[]
  returnPolicy          ReturnPolicy?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([trustpilotRating])
}

model Offer {
  id                     String           @id @default(cuid())
  variantId              String
  variant                ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  shopId                 String
  shop                   Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  condition              ProductCondition @default(NEW)
  price                  Decimal          @db.Decimal(10, 2)
  shippingCost           Decimal          @default(0) @db.Decimal(10, 2)
  totalPrice             Decimal          @db.Decimal(10, 2)
  currency               String           @default("EUR") @db.Char(3)
  deliveryMinDays        Int?
  deliveryMaxDays        Int?
  stockStatus            StockStatus      @default(UNKNOWN)
  paymentMethods         PaymentMethod[]
  shopProductRating      Decimal?         @db.Decimal(3, 2)
  shopProductReviewCount Int?
  matchConfidence        Decimal          @db.Decimal(5, 4)
  redirectUrl            String
  imageUrl               String?
  source                 OfferSource          @default(DEMO)
  sourceName             String?
  originalProductUrl     String?
  resolvedProductUrl     String?
  lastCheckedAt          DateTime?
  lastExtractionStatus   ExtractionStatus?
  lastExtractionWarnings String[]             @default([])
  merchantFeedImportId   String?
  merchantFeedImport     MerchantFeedImport?  @relation(fields: [merchantFeedImportId], references: [id], onDelete: SetNull)
  priceSnapshots         PriceSnapshot[]
  warrantyInfo           WarrantyInfo?
  rawMerchantOffers      RawMerchantOffer[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([variantId, shopId, redirectUrl])
  @@index([variantId, totalPrice])
  @@index([shopId])
  @@index([stockStatus])
  @@index([merchantFeedImportId])
}

model PriceSnapshot {
  id           String   @id @default(cuid())
  offerId      String
  offer        Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  price        Decimal  @db.Decimal(10, 2)
  shippingCost Decimal  @db.Decimal(10, 2)
  totalPrice   Decimal  @db.Decimal(10, 2)
  capturedAt   DateTime @default(now())

  @@unique([offerId, capturedAt])
  @@index([offerId, capturedAt(sort: Desc)])
}

model ReturnPolicy {
  id                    String   @id @default(cuid())
  shopId                String   @unique
  shop                  Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  returnPeriodDays      Int
  returnShippingPaidBy  String
  returnShippingDetails String?
  restockingFeePercent  Decimal? @db.Decimal(5, 2)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model WarrantyInfo {
  id             String   @id @default(cuid())
  offerId        String   @unique
  offer          Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  durationMonths Int
  provider       String
  type           String
  details        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MerchantFeedImport {
  id                    String                   @id @default(cuid())
  sourceName            String
  shopName              String?
  shopDomain            String?
  status                MerchantFeedImportStatus @default(PROCESSING)
  importedRows          Int                      @default(0)
  failedRows            Int                      @default(0)
  createdOffers         Int                      @default(0)
  updatedOffers         Int                      @default(0)
  priceSnapshotsCreated Int                      @default(0)
  errorMessages         Json?
  offers                Offer[]
  rawOffers             RawMerchantOffer[]
  createdAt             DateTime                 @default(now())
  completedAt           DateTime?

  @@index([createdAt(sort: Desc)])
  @@index([shopDomain])
}

model RawMerchantOffer {
  id             String             @id @default(cuid())
  importId       String
  import         MerchantFeedImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowNumber      Int
  rawData        Json
  imported       Boolean            @default(false)
  errorMessage   String?
  offerId        String?
  offer          Offer?             @relation(fields: [offerId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())

  @@unique([importId, rowNumber])
  @@index([offerId])
}
